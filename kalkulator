/* ============================================================
   KALKULATOR — yarn substitution & gauge calculators
   ============================================================ */

function CalculatorView() {
  return (
    <div>
      <div className="view-header">
        <div>
          <h1 className="view-title">Kalkulator</h1>
          <p className="view-desc">
            Regnehjelp for å bytte ut garn i en oppskrift, kombinere flere tråder, skalere maskeantall etter strikkefasthet, og finne riktig maskeantall fra egne mål.
          </p>
        </div>
      </div>

      <YarnSubstitutionCalc />
      <GaugeScaleCalc />
      <BodyMeasureCalc />
      <CombineThreadsCalc />
    </div>
  );
}

/* ---- 1. Bytte garn: meter mot meter ---- */
function YarnSubstitutionCalc() {
  const [oppskriftVekt, setOppskriftVekt] = useState("50");
  const [oppskriftMeter, setOppskriftMeter] = useState("170");
  const [oppskriftNoster, setOppskriftNoster] = useState("6");
  const [nyttVekt, setNyttVekt] = useState("50");
  const [nyttMeter, setNyttMeter] = useState("150");

  const totalMeterOppskrift = (Number(oppskriftMeter) / Number(oppskriftVekt || 1)) * Number(oppskriftVekt) * Number(oppskriftNoster);
  // simplifies to oppskriftMeter * oppskriftNoster, but keep formula explicit per handbook style
  const totalMeter = Number(oppskriftMeter) * Number(oppskriftNoster);
  const nyeNosterRaw = nyttMeter ? totalMeter / Number(nyttMeter) : 0;
  const nyeNosterAvrundet = Math.ceil(nyeNosterRaw);

  const valid = oppskriftMeter && oppskriftNoster && nyttMeter && Number(nyttMeter) > 0;

  return (
    <div className="calc-card">
      <h3>Bytte garn — meter mot meter</h3>
      <p className="calc-desc">
        Oppskriften ber om et bestemt antall nøster av et garn, men du har et annet garn med en annen løpelengde. Regn ut hvor mange nøster av <i>ditt</i> garn du trenger for å få like mange meter totalt.
      </p>
      <div className="form-row">
        <div className="form-field">
          <label>Oppskriftens garn: m / 50 g</label>
          <input className="input" type="number" min="0" value={oppskriftMeter} onChange={(e) => setOppskriftMeter(e.target.value)} />
        </div>
        <div className="form-field">
          <label>Antall nøster i oppskriften</label>
          <input className="input" type="number" min="0" value={oppskriftNoster} onChange={(e) => setOppskriftNoster(e.target.value)} />
        </div>
        <div className="form-field">
          <label>Ditt garn: m / 50 g</label>
          <input className="input" type="number" min="0" value={nyttMeter} onChange={(e) => setNyttMeter(e.target.value)} />
        </div>
      </div>
      {valid && (
        <div className="calc-result">
          Oppskriften krever totalt <b>{totalMeter}</b> meter garn.<br />
          <div style={{ marginTop: 8 }}>
            <span className="big">{nyeNosterAvrundet}</span> nøster av ditt garn (50 g = {nyttMeter} m)
          </div>
          <div style={{ marginTop: 4, fontSize: 12, color: "var(--walnut-soft)" }}>
            ({totalMeter} m ÷ {nyttMeter} m = {nyeNosterRaw.toFixed(2)} → rundes opp til {nyeNosterAvrundet})
          </div>
        </div>
      )}
    </div>
  );
}

/* ---- 2. Skalere strikkefasthet/maskeantall ---- */
function GaugeScaleCalc() {
  const [oppskriftFasthet, setOppskriftFasthet] = useState("20");
  const [dinFasthet, setDinFasthet] = useState("22");
  const [maskeantall, setMaskeantall] = useState("120");
  const [omganger, setOmganger] = useState("60");

  const fastOpp = Number(oppskriftFasthet);
  const fastDin = Number(dinFasthet);
  const skalafaktor = fastOpp > 0 ? fastDin / fastOpp : 0;
  const nyeMasker = maskeantall ? Math.round(skalafaktor * Number(maskeantall)) : null;
  const nyeOmganger = omganger ? Math.round(skalafaktor * Number(omganger)) : null;

  const valid = fastOpp > 0 && fastDin > 0;

  return (
    <div className="calc-card">
      <h3>Skalere maskeantall etter strikkefasthet</h3>
      <p className="calc-desc">
        Hvis din strikkefasthet (masker per 10 cm) avviker fra oppskriftens, kan du regne ut skalafaktoren og bruke den til å justere antall masker eller omganger i oppskriften.
      </p>
      <div className="form-row">
        <div className="form-field">
          <label>Oppskriftens strikkefasthet (m/10 cm)</label>
          <input className="input" type="number" min="0" value={oppskriftFasthet} onChange={(e) => setOppskriftFasthet(e.target.value)} />
        </div>
        <div className="form-field">
          <label>Din strikkefasthet (m/10 cm)</label>
          <input className="input" type="number" min="0" value={dinFasthet} onChange={(e) => setDinFasthet(e.target.value)} />
        </div>
      </div>
      <div className="form-row">
        <div className="form-field">
          <label>Maskeantall i oppskriften (valgfritt)</label>
          <input className="input" type="number" min="0" value={maskeantall} onChange={(e) => setMaskeantall(e.target.value)} />
        </div>
        <div className="form-field">
          <label>Antall omganger i oppskriften (valgfritt)</label>
          <input className="input" type="number" min="0" value={omganger} onChange={(e) => setOmganger(e.target.value)} />
        </div>
      </div>
      {valid && (
        <div className="calc-result">
          Skalafaktor: <b className="big" style={{ fontSize: 20 }}>{skalafaktor.toFixed(2)}</b>
          <div style={{ marginTop: 8, display: "flex", gap: 24, flexWrap: "wrap" }}>
            {nyeMasker !== null && (
              <div>
                <div style={{ fontSize: 11, textTransform: "uppercase", color: "var(--walnut-soft)", letterSpacing: "0.05em" }}>Nytt maskeantall</div>
                <div className="big">{nyeMasker}</div>
              </div>
            )}
            {nyeOmganger !== null && (
              <div>
                <div style={{ fontSize: 11, textTransform: "uppercase", color: "var(--walnut-soft)", letterSpacing: "0.05em" }}>Nye omganger</div>
                <div className="big">{nyeOmganger}</div>
              </div>
            )}
          </div>
          <div style={{ marginTop: 8, fontSize: 12, color: "var(--walnut-soft)" }}>
            Husk: justering opp til ~10% kan du ofte ta med pinnestørrelse i stedet. Større avvik krever skalering av maskeantallet — og om mønsteret har en rapport, må sluttresultatet være delelig med rapportens maskeantall.
          </div>
        </div>
      )}
    </div>
  );
}

/* ---- 3. Finn maskeantall fra mål og garn ---- */
function BodyMeasureCalc() {
  const [omkrets, setOmkrets] = useState("100");
  const [bevegelse, setBevegelse] = useState("8");
  const [fasthet, setFasthet] = useState("18");
  const [rapport, setRapport] = useState("");

  const totalOmkrets = Number(omkrets) + Number(bevegelse || 0);
  const masker = fasthet ? (Number(fasthet) * totalOmkrets) / 10 : 0;
  const maskerAvrundet = Math.round(masker);
  let maskerJustert = maskerAvrundet;
  if (rapport && Number(rapport) > 0) {
    const rap = Number(rapport);
    maskerJustert = Math.round(maskerAvrundet / rap) * rap;
  }

  const valid = omkrets && fasthet;

  return (
    <div className="calc-card">
      <h3>Finn maskeantall fra mål</h3>
      <p className="calc-desc">
        Mål kroppen (f.eks. brystvidde eller hofteomkrets), legg til bevegelsesvidde (5–10 cm er vanlig), og finn hvor mange masker du må legge opp basert på din strikkefasthet. Hvis mønsteret ditt har en rapport, kan du runde av til nærmeste multiplum.
      </p>
      <div className="form-row">
        <div className="form-field">
          <label>Kroppsmål (cm)</label>
          <input className="input" type="number" min="0" value={omkrets} onChange={(e) => setOmkrets(e.target.value)} />
        </div>
        <div className="form-field">
          <label>Bevegelsesvidde (cm)</label>
          <input className="input" type="number" min="0" value={bevegelse} onChange={(e) => setBevegelse(e.target.value)} />
        </div>
        <div className="form-field">
          <label>Din strikkefasthet (m/10 cm)</label>
          <input className="input" type="number" min="0" value={fasthet} onChange={(e) => setFasthet(e.target.value)} />
        </div>
        <div className="form-field">
          <label>Mønsterrapport (masker, valgfritt)</label>
          <input className="input" type="number" min="0" value={rapport} onChange={(e) => setRapport(e.target.value)} />
        </div>
      </div>
      {valid && (
        <div className="calc-result">
          Totalt mål inkl. bevegelsesvidde: <b>{totalOmkrets} cm</b>
          <div style={{ marginTop: 8 }}>
            <span className="big">{maskerAvrundet}</span> masker
            {rapport && Number(rapport) > 0 && maskerJustert !== maskerAvrundet && (
              <> → justert til <b className="big" style={{ fontSize: 20 }}>{maskerJustert}</b> masker for å passe rapporten på {rapport}</>
            )}
          </div>
          <div style={{ marginTop: 4, fontSize: 12, color: "var(--walnut-soft)" }}>
            ({fasthet} m/10 cm × {totalOmkrets} cm ÷ 10 = {masker.toFixed(1)})
          </div>
        </div>
      )}
    </div>
  );
}

/* ---- 4. Kombinere flere tråder ---- */
function CombineThreadsCalc() {
  const garngruppeOptions = Object.entries(GARNGRUPPER);
  const [trad1Gruppe, setTrad1Gruppe] = useState("A");
  const [antallTrader, setAntallTrader] = useState("2");

  // approximate mapping based on handbook: combining N threads of group X gives roughly group at index+steps
  const groupOrder = ["A", "AB", "B", "C", "D", "E", "F"];
  const stepsForThreads = { "2": 2, "3": 3, "4": 4, "8": 5 }; // rough heuristic; A+A=C (2 steps), A 3x = D, etc.

  const startIdx = groupOrder.indexOf(trad1Gruppe);
  const steps = stepsForThreads[antallTrader] || 2;
  const resultIdx = Math.min(groupOrder.length - 1, startIdx + Math.round(steps * 0.6));
  const resultGroup = groupOrder[resultIdx];

  return (
    <div className="calc-card">
      <h3>Kombinere flere tråder</h3>
      <p className="calc-desc">
        Strikker du med flere tråder samtidig (holde to eller flere nøster sammen), blir resultatet en tykkere "garngruppe". Dette er en grov pekepinn — test alltid med en prøvelapp, siden resultatet varierer med fibertype og spinning.
      </p>
      <div className="form-row">
        <div className="form-field">
          <label>Garngruppe du starter med</label>
          <select className="select" value={trad1Gruppe} onChange={(e) => setTrad1Gruppe(e.target.value)}>
            {garngruppeOptions.map(([k, g]) => <option key={k} value={k}>{k} — {g.navn}</option>)}
          </select>
        </div>
        <div className="form-field">
          <label>Antall tråder holdt sammen</label>
          <select className="select" value={antallTrader} onChange={(e) => setAntallTrader(e.target.value)}>
            <option value="2">2 tråder</option>
            <option value="3">3 tråder</option>
            <option value="4">4 tråder</option>
            <option value="8">8 tråder</option>
          </select>
        </div>
      </div>
      <div className="calc-result">
        {antallTrader} tråder av garngruppe <b>{trad1Gruppe}</b> gir omtrent garngruppe{" "}
        <span className="big">{resultGroup}</span> ({GARNGRUPPER[resultGroup].navn})
        <div style={{ marginTop: 8, fontSize: 12, color: "var(--walnut-soft)" }}>
          Tommelfingerregler fra håndboken: 2 tråder A = 1 tråd C · 3 tråder A = 1 tråd D · 4 tråder A = 1 tråd E · 8 tråder A = 1 tråd F · 2 tråder B = 1 tråd D · 2 tråder C = 1 tråd E · 4 tråder C = 1 tråd F · 2 tråder E = 1 tråd F.
        </div>
      </div>
    </div>
  );
}
