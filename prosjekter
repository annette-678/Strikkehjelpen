/* ============================================================
   PROSJEKTER — project tracker
   ============================================================ */

function emptyProject() {
  return {
    id: uid(),
    navn: "",
    type: "",
    status: "Planlagt",
    oppskrift: "",
    pinneStorrelse: "",
    garnIds: [],
    startdato: "",
    sluttdato: "",
    notater: "",
    bilder: [],
  };
}

function ProjectsView({ projects, setProjects, yarns, setYarns, showToast }) {
  const [editing, setEditing] = useState(null);
  const [showAdd, setShowAdd] = useState(false);
  const [viewing, setViewing] = useState(null);
  const [filterStatus, setFilterStatus] = useState(null);

  function handleSave(project) {
    setProjects((prev) => {
      const exists = prev.find((p) => p.id === project.id);
      if (exists) return prev.map((p) => (p.id === project.id ? project : p));
      return [project, ...prev];
    });
    setEditing(null);
    setShowAdd(false);
    setViewing(project);
    showToast("Prosjekt lagret");
  }

  function handleDelete(id) {
    setProjects((prev) => prev.filter((p) => p.id !== id));
    setViewing(null);
    showToast("Prosjekt fjernet");
  }

  const filtered = projects.filter((p) => !filterStatus || p.status === filterStatus);

  // Sort: Pågår first, then Planlagt/Idé, then Ferdig, then Lagt på vent
  const order = { "Pågår": 0, "Idé": 1, "Planlagt": 1, "Lagt på vent": 2, "Ferdig": 3 };
  const sorted = [...filtered].sort((a, b) => (order[a.status] ?? 9) - (order[b.status] ?? 9));

  function statusClass(status) {
    if (status === "Ferdig") return "ferdig";
    if (status === "Pågår") return "pagaar";
    return "planlagt";
  }

  return (
    <div>
      <div className="view-header">
        <div>
          <h1 className="view-title">Prosjekter</h1>
          <p className="view-desc">
            Hold rede på hva du strikker eller hekler nå, hva du planlegger, og hva du har fullført. Koble prosjekter til garnet du bruker for å se hvilket garn som er i bruk.
          </p>
        </div>
        <button className="btn" onClick={() => setShowAdd(true)}>+ Nytt prosjekt</button>
      </div>

      <div className="toolbar">
        <div className="chip-group" role="group" aria-label="Filtrer på status">
          {PROSJEKT_STATUS.map((s) => (
            <button key={s} className={`chip ${filterStatus === s ? "active" : ""}`} onClick={() => setFilterStatus(filterStatus === s ? null : s)}>
              {s}
            </button>
          ))}
        </div>
      </div>

      {sorted.length === 0 ? (
        <div className="empty">
          <span className="empty-icon">🧣</span>
          {projects.length === 0 ? (
            <>
              <h3>Ingen prosjekter ennå</h3>
              <p>Legg til prosjektet du jobber med — koble det til garn fra lageret, og oppdater status fra idé til ferdig.</p>
            </>
          ) : (
            <>
              <h3>Ingen treff</h3>
              <p>Ingen prosjekter med denne statusen. Prøv et annet filter.</p>
            </>
          )}
          <button className="btn" onClick={() => setShowAdd(true)}>+ Nytt prosjekt</button>
        </div>
      ) : (
        <div>
          {sorted.map((p) => {
            const linkedYarns = yarns.filter((y) => (p.garnIds || []).includes(y.id));
            return (
              <div className="project-card" key={p.id} onClick={() => setViewing(p)} role="button" tabIndex={0}
                onKeyDown={(e) => { if (e.key === "Enter") setViewing(p); }}>
                {p.bilder && p.bilder.length > 0 ? (
                  <img className="project-img" src={p.bilder[0]} alt={p.navn} />
                ) : (
                  <div className="project-img" style={{ display: "flex", alignItems: "center", justifyContent: "center", fontSize: 22 }}>🧶</div>
                )}
                <div className="project-info">
                  <h3 className="project-title">{p.navn || "Uten navn"}</h3>
                  <div className="project-meta">
                    {p.type && <>{p.type} · </>}
                    {linkedYarns.length > 0 ? `${linkedYarns.length} garn koblet` : "Ingen garn koblet"}
                    {p.pinneStorrelse && ` · pinne ${p.pinneStorrelse} mm`}
                  </div>
                  {p.notater && <div style={{ fontSize: 12.5, color: "var(--walnut-soft)" }}>{p.notater.slice(0, 100)}{p.notater.length > 100 ? "…" : ""}</div>}
                </div>
                <span className={`status-badge ${statusClass(p.status)}`}>{p.status}</span>
              </div>
            );
          })}
        </div>
      )}

      {(showAdd || editing) && (
        <ProjectFormModal
          initial={editing || emptyProject()}
          yarns={yarns}
          onSave={handleSave}
          onClose={() => { setShowAdd(false); setEditing(null); }}
          isNew={!editing}
        />
      )}

      {viewing && (
        <ProjectDetailModal
          project={viewing}
          yarns={yarns}
          onClose={() => setViewing(null)}
          onEdit={() => { setEditing(viewing); setViewing(null); }}
          onDelete={() => handleDelete(viewing.id)}
        />
      )}
    </div>
  );
}

function ProjectFormModal({ initial, yarns, onSave, onClose, isNew }) {
  const [form, setForm] = useState(initial);
  const fileInputRef = useRef(null);

  function update(field, value) {
    setForm((f) => ({ ...f, [field]: value }));
  }

  function toggleYarn(id) {
    setForm((f) => {
      const garnIds = f.garnIds || [];
      return { ...f, garnIds: garnIds.includes(id) ? garnIds.filter((g) => g !== id) : [...garnIds, id] };
    });
  }

  async function handleFiles(fileList) {
    const files = Array.from(fileList).slice(0, 6 - (form.bilder?.length || 0));
    const newImgs = [];
    for (const file of files) {
      const raw = await fileToDataUrl(file);
      const resized = await resizeImage(raw);
      newImgs.push(resized);
    }
    setForm((f) => ({ ...f, bilder: [...(f.bilder || []), ...newImgs] }));
  }

  function removeImage(idx) {
    setForm((f) => ({ ...f, bilder: f.bilder.filter((_, i) => i !== idx) }));
  }

  function handleSubmit(e) {
    e.preventDefault();
    if (!form.navn.trim()) return;
    onSave(form);
  }

  return (
    <div className="modal-overlay" onClick={(e) => { if (e.target === e.currentTarget) onClose(); }}>
      <div className="modal" role="dialog" aria-modal="true" aria-labelledby="project-modal-title">
        <div className="modal-header">
          <h2 id="project-modal-title">{isNew ? "Nytt prosjekt" : "Rediger prosjekt"}</h2>
          <button className="modal-close" onClick={onClose} aria-label="Lukk">×</button>
        </div>
        <form onSubmit={handleSubmit}>
          <div className="modal-body">
            <div className="form-row">
              <div className="form-field" style={{ flex: 2 }}>
                <label htmlFor="pnavn">Navn på prosjekt *</label>
                <input id="pnavn" className="input" value={form.navn} onChange={(e) => update("navn", e.target.value)} placeholder="f.eks. Cabled vrangbord-jakke" required />
              </div>
              <div className="form-field">
                <label htmlFor="ptype">Type</label>
                <input id="ptype" className="input" value={form.type} onChange={(e) => update("type", e.target.value)} placeholder="f.eks. Sjal, sokker, genser" />
              </div>
            </div>

            <div className="form-row">
              <div className="form-field">
                <label htmlFor="pstatus">Status</label>
                <select id="pstatus" className="select" value={form.status} onChange={(e) => update("status", e.target.value)}>
                  {PROSJEKT_STATUS.map((s) => <option key={s} value={s}>{s}</option>)}
                </select>
              </div>
              <div className="form-field">
                <label htmlFor="ppinne">Pinnestørrelse (mm)</label>
                <input id="ppinne" className="input" value={form.pinneStorrelse} onChange={(e) => update("pinneStorrelse", e.target.value)} placeholder="f.eks. 4" />
              </div>
            </div>

            <div className="form-row">
              <div className="form-field">
                <label htmlFor="poppskrift">Oppskrift / kilde</label>
                <input id="poppskrift" className="input" value={form.oppskrift} onChange={(e) => update("oppskrift", e.target.value)} placeholder="f.eks. Drops design 12345, eller eget design" />
              </div>
            </div>

            <div className="form-row">
              <div className="form-field">
                <label htmlFor="pstart">Startet</label>
                <input id="pstart" className="input" type="date" value={form.startdato} onChange={(e) => update("startdato", e.target.value)} />
              </div>
              <div className="form-field">
                <label htmlFor="pferdig">Ferdig</label>
                <input id="pferdig" className="input" type="date" value={form.sluttdato} onChange={(e) => update("sluttdato", e.target.value)} />
              </div>
            </div>

            <div className="form-row">
              <div className="form-field">
                <label>Garn brukt i prosjektet</label>
                {yarns.length === 0 ? (
                  <p style={{ fontSize: 12.5, color: "var(--walnut-soft)", margin: 0 }}>Du har ikke lagt inn garn i lageret ennå.</p>
                ) : (
                  <div className="chip-group">
                    {yarns.map((y) => (
                      <button
                        type="button"
                        key={y.id}
                        className={`chip ${(form.garnIds || []).includes(y.id) ? "active" : ""}`}
                        onClick={() => toggleYarn(y.id)}
                      >
                        {y.navn || "Uten navn"}
                      </button>
                    ))}
                  </div>
                )}
              </div>
            </div>

            <div className="form-row">
              <div className="form-field">
                <label htmlFor="pnotater">Notater</label>
                <textarea id="pnotater" className="input" value={form.notater} onChange={(e) => update("notater", e.target.value)} placeholder="Fremgang, justeringer, ting å huske på…" />
              </div>
            </div>

            <div className="form-row">
              <div className="form-field">
                <label>Bilder av prosjektet</label>
                <div className="image-upload" onClick={() => fileInputRef.current?.click()}>
                  📷 Trykk for å laste opp bilde(r) — maks 6
                </div>
                <input
                  ref={fileInputRef}
                  type="file"
                  accept="image/*"
                  multiple
                  className="visually-hidden"
                  onChange={(e) => { if (e.target.files.length) handleFiles(e.target.files); e.target.value = ""; }}
                />
                {form.bilder && form.bilder.length > 0 && (
                  <div className="image-preview-row">
                    {form.bilder.map((src, i) => (
                      <div className="image-preview-wrap" key={i}>
                        <img className="image-preview" src={src} alt={`Bilde ${i + 1}`} />
                        <button type="button" className="image-preview-remove" onClick={() => removeImage(i)} aria-label="Fjern bilde">×</button>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
          <div className="modal-footer">
            <button type="button" className="btn btn-outline" onClick={onClose}>Avbryt</button>
            <button type="submit" className="btn">Lagre prosjekt</button>
          </div>
        </form>
      </div>
    </div>
  );
}

function ProjectDetailModal({ project, yarns, onClose, onEdit, onDelete }) {
  const [activeImg, setActiveImg] = useState(0);
  const [confirmDelete, setConfirmDelete] = useState(false);
  const linkedYarns = yarns.filter((y) => (project.garnIds || []).includes(y.id));

  function statusClass(status) {
    if (status === "Ferdig") return "ferdig";
    if (status === "Pågår") return "pagaar";
    return "planlagt";
  }

  return (
    <div className="modal-overlay" onClick={(e) => { if (e.target === e.currentTarget) onClose(); }}>
      <div className="modal" role="dialog" aria-modal="true" aria-labelledby="project-detail-title" style={{ maxWidth: 680 }}>
        <div className="modal-header">
          <h2 id="project-detail-title">{project.navn}</h2>
          <button className="modal-close" onClick={onClose} aria-label="Lukk">×</button>
        </div>
        <div className="modal-body">
          <div className="detail-grid">
            <div className="detail-images">
              {project.bilder && project.bilder.length > 0 ? (
                <>
                  <img className="detail-img-main" src={project.bilder[activeImg]} alt={project.navn} />
                  {project.bilder.length > 1 && (
                    <div className="detail-thumbs">
                      {project.bilder.map((src, i) => (
                        <img key={i} className={`detail-thumb ${i === activeImg ? "active" : ""}`} src={src} alt={`Bilde ${i + 1}`} onClick={() => setActiveImg(i)} />
                      ))}
                    </div>
                  )}
                </>
              ) : (
                <div className="detail-img-main" style={{ display: "flex", alignItems: "center", justifyContent: "center", fontSize: 40 }}>🧣</div>
              )}
            </div>
            <div>
              <span className={`status-badge ${statusClass(project.status)}`} style={{ marginBottom: 10, display: "inline-block" }}>{project.status}</span>
              <div className="detail-field-grid">
                <div className="detail-field"><span className="label">Type</span><span className="value">{project.type || "—"}</span></div>
                <div className="detail-field"><span className="label">Pinnestørrelse</span><span className="value">{project.pinneStorrelse ? `${project.pinneStorrelse} mm` : "—"}</span></div>
                <div className="detail-field"><span className="label">Oppskrift</span><span className="value">{project.oppskrift || "—"}</span></div>
                <div className="detail-field"><span className="label">Startet</span><span className="value">{project.startdato || "—"}</span></div>
                <div className="detail-field"><span className="label">Ferdig</span><span className="value">{project.sluttdato || "—"}</span></div>
              </div>

              {linkedYarns.length > 0 && (
                <div className="detail-field" style={{ marginBottom: 14 }}>
                  <span className="label">Garn brukt</span>
                  <div className="yarn-card-tags" style={{ marginTop: 4 }}>
                    {linkedYarns.map((y) => (
                      <span key={y.id} className="tag" style={{ display: "flex", alignItems: "center", gap: 4 }}>
                        <span className="swatch" style={{ background: y.fargekode || "#C9AF97" }} /> {y.navn}
                      </span>
                    ))}
                  </div>
                </div>
              )}

              {project.notater && (
                <div className="detail-field">
                  <span className="label">Notater</span>
                  <div className="notes-block">{project.notater}</div>
                </div>
              )}
            </div>
          </div>
        </div>
        <div className="modal-footer" style={{ justifyContent: "space-between" }}>
          {confirmDelete ? (
            <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
              <span style={{ fontSize: 13, color: "var(--walnut-soft)" }}>Slette dette prosjektet?</span>
              <button className="btn btn-danger btn-sm" onClick={onDelete}>Ja, slett</button>
              <button className="btn btn-outline btn-sm" onClick={() => setConfirmDelete(false)}>Avbryt</button>
            </div>
          ) : (
            <button className="btn btn-danger btn-sm" onClick={() => setConfirmDelete(true)}>Slett prosjekt</button>
          )}
          <button className="btn btn-outline" onClick={onEdit}>Rediger</button>
        </div>
      </div>
    </div>
  );
}
