cat >> /home/claude/work/garnlager.jsx << 'EOF'

/* ============================================================
   GARNLAGER — yarn inventory
   ============================================================ */

function emptyYarn() {
  return {
    id: uid(),
    navn: "",
    produsent: "",
    farge: "",
    fargekode: "#C9AF97",
    fibertype: "Ull",
    fibertypeDetalj: "",
    garngruppe: "C",
    lopelengdePer50g: "",
    totalVekt: "",
    gjenvaerendeVekt: "",
    antallNoster: "",
    notater: "",
    bilder: [],
  };
}

function YarnView({ yarns, setYarns, showToast, projects }) {
  const [search, setSearch] = useState("");
  const [filterGruppe, setFilterGruppe] = useState(null);
  const [filterFiber, setFilterFiber] = useState(null);
  const [editing, setEditing] = useState(null); // yarn object being edited, or null
  const [viewing, setViewing] = useState(null); // yarn being viewed in detail
  const [showAdd, setShowAdd] = useState(false);

  const filtered = yarns.filter((y) => {
    const matchesSearch =
      !search ||
      [y.navn, y.produsent, y.farge, y.fibertype, y.fibertypeDetalj, y.notater]
        .join(" ")
        .toLowerCase()
        .includes(search.toLowerCase());
    const matchesGruppe = !filterGruppe || y.garngruppe === filterGruppe;
    const matchesFiber = !filterFiber || y.fibertype === filterFiber;
    return matchesSearch && matchesGruppe && matchesFiber;
  });

  function handleSave(yarn) {
    setYarns((prev) => {
      const exists = prev.find((y) => y.id === yarn.id);
      if (exists) return prev.map((y) => (y.id === yarn.id ? yarn : y));
      return [yarn, ...prev];
    });
    setEditing(null);
    setShowAdd(false);
    setViewing(yarn);
    showToast("Garn lagret");
  }

  function handleDelete(id) {
    setYarns((prev) => prev.filter((y) => y.id !== id));
    setViewing(null);
    showToast("Garn fjernet fra lageret");
  }

  const usedFibers = [...new Set(yarns.map((y) => y.fibertype).filter(Boolean))];

  return (
    <div>
      <div className="view-header">
        <div>
          <h1 className="view-title">Garnlager</h1>
          <p className="view-desc">
            Hold oversikt over garnet ditt — fibertype, farge, mengde og bilder. Klikk på et nøste for å se detaljer, justere gjenværende mengde eller koble det til et prosjekt.
          </p>
        </div>
        <button className="btn" onClick={() => setShowAdd(true)}>+ Legg til garn</button>
      </div>

      <div className="toolbar">
        <input
          className="input search-input"
          type="search"
          placeholder="Søk på navn, produsent, farge, fiber…"
          value={search}
          onChange={(e) => setSearch(e.target.value)}
          aria-label="Søk i garnlager"
        />
      </div>

      <div className="toolbar">
        <div className="chip-group" role="group" aria-label="Filtrer på garngruppe">
          {Object.entries(GARNGRUPPER).map(([key, g]) => (
            <button
              key={key}
              className={`chip ${filterGruppe === key ? "active" : ""}`}
              onClick={() => setFilterGruppe(filterGruppe === key ? null : key)}
            >
              {key} · {g.navn}
            </button>
          ))}
        </div>
      </div>
      {usedFibers.length > 0 && (
        <div className="toolbar">
          <div className="chip-group" role="group" aria-label="Filtrer på fibertype">
            {usedFibers.map((f) => (
              <button
                key={f}
                className={`chip ${filterFiber === f ? "active" : ""}`}
                onClick={() => setFilterFiber(filterFiber === f ? null : f)}
              >
                {f}
              </button>
            ))}
          </div>
        </div>
      )}

      {filtered.length === 0 ? (
        <div className="empty">
          <span className="empty-icon">🧶</span>
          {yarns.length === 0 ? (
            <>
              <h3>Garnlageret er tomt</h3>
              <p>Legg til det første nøstet ditt for å starte oversikten. Du kan legge til bilder, fibertype, farge og hvor mye du har igjen.</p>
            </>
          ) : (
            <>
              <h3>Ingen treff</h3>
              <p>Ingen garn matcher søket eller filtrene dine. Prøv å justere eller nullstille filtrene.</p>
            </>
          )}
          <button className="btn" onClick={() => setShowAdd(true)}>+ Legg til garn</button>
        </div>
      ) : (
        <div className="grid">
          {filtered.map((y) => (
            <YarnCard key={y.id} yarn={y} onClick={() => setViewing(y)} />
          ))}
        </div>
      )}

      {(showAdd || editing) && (
        <YarnFormModal
          initial={editing || emptyYarn()}
          onSave={handleSave}
          onClose={() => { setShowAdd(false); setEditing(null); }}
          isNew={!editing}
        />
      )}

      {viewing && (
        <YarnDetailModal
          yarn={viewing}
          projects={projects}
          onClose={() => setViewing(null)}
          onEdit={() => { setEditing(viewing); setViewing(null); }}
          onDelete={() => handleDelete(viewing.id)}
          onUpdate={(updated) => {
            setYarns((prev) => prev.map((y) => (y.id === updated.id ? updated : y)));
            setViewing(updated);
          }}
        />
      )}
    </div>
  );
}

function YarnCard({ yarn, onClick }) {
  const gruppe = GARNGRUPPER[yarn.garngruppe];
  const totalMeter =
    yarn.lopelengdePer50g && yarn.gjenvaerendeVekt
      ? Math.round((Number(yarn.lopelengdePer50g) / 50) * Number(yarn.gjenvaerendeVekt))
      : null;

  return (
    <div className="yarn-card" onClick={onClick} role="button" tabIndex={0}
      onKeyDown={(e) => { if (e.key === "Enter") onClick(); }}>
      {yarn.bilder && yarn.bilder.length > 0 ? (
        <img className="yarn-card-img" src={yarn.bilder[0]} alt={yarn.navn || "Garn"} />
      ) : (
        <div className="yarn-card-noimg">
          <span className="swatch" style={{ width: 36, height: 36, background: yarn.fargekode || "#C9AF97" }} />
        </div>
      )}
      <div className="yarn-card-body">
        <h3 className="yarn-card-title">{yarn.navn || "Uten navn"}</h3>
        <div className="yarn-card-meta">
          {yarn.produsent && <>{yarn.produsent} · </>}
          {yarn.fibertype}
        </div>
        <div className="yarn-card-tags">
          {gruppe && <span className={`tag group-${yarn.garngruppe}`}>{yarn.garngruppe} · {gruppe.navn}</span>}
          {yarn.farge && (
            <span className="tag" style={{ display: "flex", alignItems: "center", gap: 4 }}>
              <span className="swatch" style={{ background: yarn.fargekode || "#C9AF97" }} /> {yarn.farge}
            </span>
          )}
        </div>
        <div className="yarn-card-amount">
          <span>
            {yarn.gjenvaerendeVekt ? `${yarn.gjenvaerendeVekt} g igjen` : "Vekt ikke angitt"}
            {yarn.antallNoster ? ` · ${yarn.antallNoster} nøster` : ""}
          </span>
          {totalMeter !== null && <b>{totalMeter} m</b>}
        </div>
      </div>
    </div>
  );
}
EOF
